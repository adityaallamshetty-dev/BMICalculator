<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tracker_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <ImageButton
            android:id="@+id/btnBackFitness"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_tracker_card"
            android:padding="10dp"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/tracker_primary_text" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/fitness_plus_title"
            android:textColor="@color/tracker_primary_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/fitness_plus_subtitle"
            android:textColor="@color/tracker_secondary_text"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_tracker_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Premium Features"
                android:textColor="@color/tracker_primary_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="- Guided workouts&#10;- Custom goals&#10;- Weekly coaching&#10;- Family sharing"
                android:textColor="@color/tracker_secondary_text"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartTrial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/start_trial"
                app:backgroundTint="@color/tracker_accent"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRestorePlan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/restore_plan"
                android:textColor="@color/tracker_primary_text"
                app:backgroundTint="@color/tracker_chip_bg"
                app:cornerRadius="14dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
